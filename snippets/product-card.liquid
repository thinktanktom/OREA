
{% comment %}
  Renders a premium product card for the ORÉA collection.
  Accepts:
  - product: {Object} Product object
{% endcomment %}

<div class="group cursor-pointer flex flex-col space-y-6">
  <a href="{{ product.url }}" class="block">
    <div class="relative aspect-[4/5] overflow-hidden bg-orea-linen/40 flex items-center justify-center">
      {%- if product.featured_image != blank -%}
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          alt="{{ product.featured_image.alt | escape }}"
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-1000 ease-out scale-100 group-hover:scale-105 {% if product.images[1] != blank %}group-hover:opacity-0{% endif %}"
        >
        
        {%- if product.images[1] != blank -%}
          <img
            src="{{ product.images[1] | image_url: width: 800 }}"
            alt="{{ product.images[1].alt | escape }}"
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover transition-all duration-1000 ease-out opacity-0 group-hover:opacity-100 scale-105 group-hover:scale-100"
          >
        {%- endif -%}
      {%- else -%}
        <div class="text-[10px] uppercase tracking-ultra-wide text-orea-taupe/50 text-center px-4">
          Image Coming Soon
        </div>
      {%- endif -%}

      {%- if product.available == false -%}
        <div class="absolute top-4 left-4 bg-white/90 px-3 py-1 text-[8px] uppercase tracking-extra-wide text-orea-dark">
          Sold Out
        </div>
      {%- elsif product.tags contains 'New' -%}
        <div class="absolute top-4 left-4 bg-orea-dark px-3 py-1 text-[8px] uppercase tracking-extra-wide text-white">
          New
        </div>
      {%- endif -%}
    </div>

    <div class="flex flex-col items-center text-center space-y-2 pt-6 pb-8">
      <h3 class="text-[11px] md:text-xs font-medium uppercase tracking-ultra-wide text-orea-dark leading-relaxed">
        {{ product.title }}
      </h3>
      <p class="text-[10px] text-orea-taupe font-light tracking-extra-wide">
        {{ product.price | money_with_currency }}
      </p>
    </div>
  </a>
</div>
