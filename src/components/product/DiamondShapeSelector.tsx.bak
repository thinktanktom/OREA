import React from 'react';

const DIAMOND_SHAPES = [
  'Round', 'Oval', 'Pear', 'Marquise', 'Princess',
  'Emerald', 'Radiant', 'Asscher', 'Cushion', 'Heart'
] as const;

export type DiamondShape = typeof DIAMOND_SHAPES[number];

const ShapeIcon: React.FC<{ shape: string; className?: string }> = ({ shape, className = 'w-7 h-7' }) => {
  switch (shape) {
    case 'Round':
      return <img src="data:image/png;base64," alt="Round" className={className} />;

    case 'Oval':
      return <img src="data:image/png;base64," alt="Oval" className={className} />;

    case 'Pear':
      return <img src="data:image/png;base64," alt="Pear" className={className} />;

    case 'Marquise':
      return <img src="data:image/png;base64," alt="Marquise" className={className} />;

    case 'Princess':
      return <img src="data:image/png;base64," alt="Princess" className={className} />;

    case 'Emerald':
      return <img src="data:image/png;base64," alt="Emerald" className={className} />;

    case 'Radiant':
      return <img src="data:image/png;base64," alt="Radiant" className={className} />;

    case 'Asscher':
      return <img src="data:image/png;base64," alt="Asscher" className={className} />;

    case 'Cushion':
      return <img src="data:image/png;base64," alt="Cushion" className={className} />;

    case 'Heart':
      return <img src="data:image/png;base64," alt="Heart" className={className} />;

    default:
      return null;
  }
};

interface DiamondShapeSelectorProps {
  shapes?: string[];
  selectedShape: string;
  onShapeChange: (shape: string) => void;
}

const DiamondShapeSelector: React.FC<DiamondShapeSelectorProps> = ({
  shapes = DIAMOND_SHAPES as unknown as string[],
  selectedShape,
  onShapeChange
}) => {
  return (
    <div className="flex flex-col gap-6">
      <div className="flex items-center gap-2">
        <label className="text-micro font-bold uppercase tracking-widest text-orea-dark">
          {'Shape:'}
        </label>
        <span className="text-body-sm font-light text-orea-taupe tracking-wide">
          {selectedShape}
        </span>
      </div>
      <div className="flex flex-wrap gap-x-6 gap-y-8 items-end">
        {shapes.map((shape) => {
          const isActive = selectedShape === shape;
          return (
            <button
              key={shape}
              onClick={() => onShapeChange(shape)}
              className="relative flex flex-col items-center group transition-all duration-300 focus:outline-none"
              aria-label={`Select ${shape} shape`}
              aria-pressed={isActive}
            >
              <div
                className={`transition-all duration-500 mb-2 ${
                  isActive
                    ? 'opacity-100 scale-110'
                    : 'opacity-30 group-hover:opacity-70'
                }`}
              >
                <ShapeIcon shape={shape} className="w-7 h-7" />
              </div>
              {isActive && (
                <div className="absolute -bottom-2 left-0 right-0 h-px bg-orea-dark animate-in slide-in-from-bottom-1" />
              )}
            </button>
          );
        })}
      </div>
    </div>
  );
};

export { ShapeIcon, DIAMOND_SHAPES };
export default DiamondShapeSelector;
