{% comment %}
  ORÉA Collection Template
  ========================
  Converted from: React App.tsx
  
  This template displays a filterable, sortable collection grid
  with category navigation and diamond shape filtering
{% endcomment %}

<div class="min-h-screen bg-[#F9F6F1] text-[#4A3F35] selection:bg-[#E8DFD3]">
  
  {% section 'collection-header' %}
  
  <main class="max-w-screen-2xl mx-auto px-6 md:px-12 pb-32">
    
    <!-- Toolbar Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 text-[10px] uppercase tracking-[0.4em] text-[#4A3F35]/70 border-b border-[#E8DFD3]/40 pb-6 gap-4">
      
      <div class="flex items-center gap-6">
        <span class="opacity-60" id="product-count">
          {{ collection.products.size }} Pieces
        </span>
        <button 
          id="clear-filters"
          class="hidden hover:text-[#4A3F35] border-l border-[#E8DFD3] pl-6 transition-colors font-medium underline underline-offset-4"
        >
          Clear
        </button>
      </div>
      
      <div class="flex gap-10 items-center">
        
        <!-- Shape Filter Dropdown -->
        <div class="relative" id="shape-filter-container">
          <button 
            id="shape-filter-toggle"
            class="flex items-center gap-2 hover:text-[#4A3F35] transition-colors font-medium"
          >
            <span id="shape-filter-label">Shape</span>
            <svg class="w-3 h-3 transition-transform duration-500" id="shape-filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div 
            id="shape-filter-dropdown"
            class="hidden absolute right-0 top-full mt-4 w-48 bg-[#F9F6F1] border border-[#E8DFD3] shadow-sm z-50 py-4 max-h-80 overflow-y-auto"
          >
            <button 
              class="shape-filter-option w-full text-left px-6 py-2 text-[10px] tracking-[0.35em] transition-colors uppercase text-[#4A3F35] font-bold bg-[#E8DFD3]/20" 
              data-shape="all"
            >
              All Shapes
            </button>
            {% assign diamond_shapes = "Round,Oval,Pear,Marquise,Princess,Emerald,Radiant,Asscher,Cushion,Heart" | split: "," %}
            {% for shape in diamond_shapes %}
              <button 
                class="shape-filter-option w-full text-left px-6 py-2 text-[10px] tracking-[0.35em] transition-colors uppercase text-[#4A3F35]/60 hover:text-[#4A3F35]" 
                data-shape="{{ shape | handleize }}"
              >
                {{ shape }}
              </button>
            {% endfor %}
          </div>
        </div>

        <!-- Sort Dropdown -->
        <div class="relative" id="sort-container">
          <button 
            id="sort-toggle"
            class="flex items-center gap-2 hover:text-[#4A3F35] transition-colors font-medium"
          >
            <span id="sort-label">Sort: Featured</span>
            <svg class="w-3 h-3 transition-transform duration-500" id="sort-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div 
            id="sort-dropdown"
            class="hidden absolute right-0 top-full mt-4 w-56 bg-[#F9F6F1] border border-[#E8DFD3] shadow-sm z-50 py-4"
          >
            <button class="sort-option w-full text-left px-6 py-2 text-[10px] tracking-[0.35em] transition-colors uppercase text-[#4A3F35] font-bold bg-[#E8DFD3]/20" data-sort="featured">Featured</button>
            <button class="sort-option w-full text-left px-6 py-2 text-[10px] tracking-[0.35em] transition-colors uppercase text-[#4A3F35]/60 hover:text-[#4A3F35]" data-sort="best-selling">Best Selling</button>
            <button class="sort-option w-full text-left px-6 py-2 text-[10px] tracking-[0.35em] transition-colors uppercase text-[#4A3F35]/60 hover:text-[#4A3F35]" data-sort="price-low">Price, Low To High</button>
            <button class="sort-option w-full text-left px-6 py-2 text-[10px] tracking-[0.35em] transition-colors uppercase text-[#4A3F35]/60 hover:text-[#4A3F35]" data-sort="price-high">Price, High To Low</button>
          </div>
        </div>

      </div>
    </div>

    <!-- Product Grid -->
    <div id="product-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16 md:gap-x-12 md:gap-y-24">
      {% for product in collection.products %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden col-span-full py-40 text-center opacity-40">
      <p class="text-[10px] tracking-[0.5em] uppercase">No pieces found in this selection</p>
    </div>

  </main>
  
</div>

<script src="{{ 'collection-filtering.js' | asset_url }}" defer></script>
